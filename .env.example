# ==========================================================================
# VARSAL Systems — Variables de entorno
# Copia este archivo como .env.local y completa los valores reales.
# NUNCA subas .env.local al control de versiones.
# ==========================================================================

# --- Base de datos (PostgreSQL / Neon) ---
# Ejemplo Neon: postgresql://usuario:password@ep-xxx.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=

# --- Panel de administración (/admin) ---
# Contraseña de acceso al panel. Usa una contraseña fuerte.
ADMIN_PASSWORD=
# Secreto para firmar la cookie de sesión (cadena larga y aleatoria).
# Genera una con: openssl rand -hex 32
ADMIN_SESSION_SECRET=

# --- Notificaciones por email (Resend) ---
# Si no se configuran, el formulario sigue funcionando y solo guarda en BD.
# API key desde https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# Remitente. El dominio DEBE estar verificado en Resend.
# (para pruebas rápidas puede usar: onboarding@resend.dev)
MAIL_FROM="VARSAL Systems <contacto@varsalsystems.com>"
# Correo(s) que reciben las notificaciones internas (separados por coma).
CONTACT_NOTIFY_TO=varsalsystems@gmail.com

# --- URL pública del sitio ---
# Se usa para mostrar el logo en los correos (debe ser accesible públicamente).
APP_URL=https://www.varsalsystems.com

# --- Verificación en motores de búsqueda (opcional) ---
# Google ya está verificado vía public/googleddd09d383ab55ebb.html (no requiere variable).
# Bing (usado por defecto en Microsoft Edge): código de Bing Webmaster Tools
# (Configuración > Verificación de propiedad > meta tag, valor del atributo "content").
BING_SITE_VERIFICATION=
# Yandex Webmaster (opcional, tráfico ruso/internacional).
YANDEX_SITE_VERIFICATION=

# --- IndexNow (indexación rápida en Bing/Yandex/Seznam) ---
# Debe coincidir EXACTAMENTE con el nombre del archivo public/{clave}.txt
# (contenido = la misma clave). Genera una con: openssl rand -hex 16
INDEXNOW_KEY=
# Secreto para autorizar el cron semanal (/api/cron/indexnow). Genera con:
# openssl rand -hex 32. Debe configurarse también en Vercel > Cron Jobs si
# Vercel requiere el header Authorization manualmente.
CRON_SECRET=
